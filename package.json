    "@tauri-apps/plugin-window": "^2.0.0-alpha.1",
    "@types/three": "^0.184.1",
    "appwrite": "^26.0.0",
    "lucide-react": "^1.21.0",
    "node-appwrite": "^26.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "three": "^0.184.0",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0"
